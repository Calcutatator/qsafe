{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qsafe.info/data/schema/project-index.schema.json",
  "title": "qsafe project index",
  "type": "object",
  "required": ["projects"],
  "additionalProperties": false,
  "properties": {
    "projects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/projectIndexEntry"
      }
    }
  },
  "$defs": {
    "projectIndexEntry": {
      "type": "object",
      "required": ["id", "name", "type", "status"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "parent": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "status": {
          "type": "string",
          "enum": ["assessed", "queued"]
        },
        "reviewed": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      }
    }
  }
}
