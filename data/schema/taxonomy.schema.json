{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qsafe.info/data/schema/taxonomy.schema.json",
  "title": "qsafe taxonomy",
  "type": "object",
  "required": ["meta", "cores"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "name",
        "version",
        "updated",
        "description",
        "lens",
        "status_values",
        "primitive_values",
        "maturity_values",
        "applicability_values",
        "applicability_notes"
      ],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "description": { "type": "string", "minLength": 1 },
        "lens": {
          "type": "object",
          "required": ["signatures", "encryption", "pairings", "hash", "depends"],
          "additionalProperties": false,
          "properties": {
            "signatures": { "type": "string", "minLength": 1 },
            "encryption": { "type": "string", "minLength": 1 },
            "pairings": { "type": "string", "minLength": 1 },
            "hash": { "type": "string", "minLength": 1 },
            "depends": { "type": "string", "minLength": 1 }
          }
        },
        "status_values": {
          "type": "array",
          "items": { "enum": ["breakable", "depends", "safe"] }
        },
        "primitive_values": {
          "type": "array",
          "items": { "enum": ["signatures", "encryption", "pairings", "hash", "depends"] }
        },
        "maturity_values": {
          "type": "array",
          "items": { "enum": ["standardized", "deployed", "prototype", "research", "none"] }
        },
        "applicability_values": {
          "type": "array",
          "items": { "enum": ["universal", "common", "conditional"] }
        },
        "applicability_notes": { "type": "string", "minLength": 1 }
      }
    },
    "cores": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/core"
      }
    }
  },
  "$defs": {
    "core": {
      "type": "object",
      "required": ["id", "name", "label", "at_a_glance", "applicability", "notes", "subsections"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "integer", "minimum": 1, "maximum": 5 },
        "name": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "at_a_glance": { "enum": ["breakable", "depends", "safe"] },
        "applicability": { "enum": ["universal", "common", "conditional"] },
        "notes": { "type": "string", "minLength": 1 },
        "subsections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/component"
          }
        }
      }
    },
    "component": {
      "type": "object",
      "required": [
        "subsection_id",
        "subsection_label",
        "one_liner",
        "what_it_is",
        "quantum_proof_requirement",
        "primitive_at_risk",
        "status",
        "fix_maturity",
        "applicability"
      ],
      "additionalProperties": false,
      "properties": {
        "subsection_id": { "type": "string", "pattern": "^[1-5]\\.\\d+$" },
        "subsection_label": { "type": "string", "minLength": 1 },
        "one_liner": { "type": "string", "minLength": 1 },
        "what_it_is": { "type": "string", "minLength": 1 },
        "quantum_proof_requirement": { "type": "string", "minLength": 1 },
        "primitive_at_risk": { "enum": ["signatures", "encryption", "pairings", "hash", "depends"] },
        "status": { "enum": ["breakable", "depends", "safe"] },
        "fix_maturity": { "enum": ["standardized", "deployed", "prototype", "research", "none"] },
        "applicability": { "enum": ["universal", "common", "conditional"] }
      }
    }
  }
}
